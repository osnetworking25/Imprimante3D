#!/usr/bin/env python3

import sys, os, config

def main():
    args = sys.argv[1:]

    files = config.pop_and_resolve_base_arg(args)

    for name in args:
        changed = False

        for file in files:
            if os.path.exists(file):
                if config.enable(file, name):
                    changed = True

        if not changed:
            print(f"ERROR: Can't find {name}")
            exit(1)

if __name__ == "__main__":
    main()
